# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Application Configuration
VITE_APP_NAME=Evexía
VITE_APP_ENV=development

# Optional: Feature Flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_MODE=true

# Auth: use httpOnly cookies (backend must have AUTH_USE_HTTPONLY_COOKIES=true)
# VITE_AUTH_USE_COOKIES=false

# Azure AD SSO (Phase 1 — Sign in with Microsoft)
# Set to "true" to show the "Sign in with Microsoft" button on the login page.
# Backend must have AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_REDIRECT_URI / AZURE_FRONTEND_REDIRECT_URI set.
VITE_AZURE_SSO_ENABLED=false
